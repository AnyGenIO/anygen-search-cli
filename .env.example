# ─── hsearch / anygen-search-cli — provider API keys ──────────────────────
#
# At least ONE provider key is required. All providers are optional;
# hsearch auto-detects which keys are set and only enables those.
#
# Where to put this file:
#   1. Shell/process exports always win.
#   2. Explicit file:  $HSEARCH_ENV_FILE
#   3. Project-local:  ./.env             (for dev)
#   4. Active Hermes profile: $HERMES_HOME/.env
#   5. User-level:     ~/.hermes/.env     (global fallback)
#
# Get keys from:
#   Brave     — https://api.search.brave.com/app/keys
#   Serper    — https://serper.dev/api-key
#   Exa       — https://dashboard.exa.ai/
#   Tavily    — https://app.tavily.com/
#   Firecrawl — https://www.firecrawl.dev/app/api-keys
#   Jina      — https://jina.ai/?sui=apikey   (FREE 1M tokens, no card)
#
# ──────────────────────────────────────────────────────────────────────────

# Brave Search API — best for general web + privacy-respecting results
BRAVE_API_KEY=

# Serper.dev — Google SERP wrapper (web/news/images/videos/shopping/places)
SERPER_API_KEY=

# Exa (formerly Metaphor) — neural / semantic search, great for research
EXA_API_KEY=

# Tavily — LLM-optimized search with built-in answer synthesis
TAVILY_API_KEY=

# Firecrawl — search + crawl + extract (multi-source web/news/images merge)
FIRECRAWL_API_KEY=

# Jina Reader — URL → clean markdown (also a free search backend)
JINA_API_KEY=


# ─── Optional runtime tuning ──────────────────────────────────────────────

# Per-request HTTP timeout (seconds). Default 20.
# HSEARCH_TIMEOUT=20

# Cache TTL in seconds. Default 3600 (1h). Set 0 to effectively disable.
# HSEARCH_CACHE_TTL=3600

# Override cache directory. Default ~/.cache/hsearch
# HSEARCH_CACHE_DIR=
